# InSite Health System — Backend Environment Variables
# Copy this file to .env and fill in all values before running the server

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000

# ── MongoDB ────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/insite

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_64_character_random_secret_here
JWT_EXPIRES_IN=24h

# ── Email / SMTP (Nodemailer) ───────────────────────────────────────────────
# Gmail: use an App Password (requires 2FA enabled on the account)
# SendGrid: use smtp.sendgrid.net / port 587 / apikey as EMAIL_USER / API key as EMAIL_PASS
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=InSite Health System <noreply@insitehealth.com>

# ── CORS ───────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production: your deployed frontend URL
CORS_ORIGIN=http://localhost:5173

# ── Calendly Webhook ────────────────────────────────────────────────────────
# Found in Calendly → Integrations → Webhooks → your webhook → Signing key
# Leave blank in development to skip signature verification (not recommended in prod)
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_signing_key_here
